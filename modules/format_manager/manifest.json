  "status": "stable",
  "categories": [
    "utility",
    "formatting",
    "text"
  ],
  "tags": [
    "formatter",
    "markdown",
    "sanitizer",
    "table",
    "error-box",
    "event-bus"
  ],
  "dependencies": [],
  "actions": [
    {
      "name": "format_output",
      "description": "格式化输出（代码/文本/表格/列表/其他）",
      "permission": "user",
      "aliases": [
        "格式化输出",
        "美化内容",
        "排版内容"
      ]
    },
    {
      "name": "format_error",
      "description": "格式化错误信息到装饰框",
