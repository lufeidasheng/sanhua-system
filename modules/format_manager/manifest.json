{
  "name": "format_manager",
  "version": "1.0.2",
  "title": "三花聚顶 · format_manager（统一格式化输出）",
  "author": "三花聚顶开发团队",
  "description": "统一格式化输出（代码/文本/表格/错误/文件），带安全清洗、日志与截断，并支持事件总线调用。",
